---
x-config: &network_config
  network_mode: "service:tailscale"

services:
  prometheus:
    image: "prom/prometheus:v3.8.1"
    <<: *network_config
    volumes:
      - /home/observability/prometheus/data:/prometheus
      - /home/observability/prometheus/config:/etc/prometheus
    command:
      - '--config.file=/etc/prometheus/prometheus.yml'
      - '--storage.tsdb.path=/prometheus'
      - '--web.enable-lifecycle'
      - '--storage.tsdb.retention.time={{ observability_prometheus_retention }}'
      - '--enable-feature=memory-snapshot-on-shutdown'
      - '--enable-feature=auto-gomaxprocs'
      - '--enable-feature=native-histograms'
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "wget", "--spider", "http://localhost:9090/-/healthy" ]
      interval: 30s
      timeout: 10s
      retries: 3

  grafana:
    image: "grafana/grafana:12.3.1"
    <<: *network_config
    volumes:
      - /home/observability/grafana/data:/var/lib/grafana
    environment:
      GF_SECURITY_ADMIN_PASSWORD: "{{ grafana_admin_password }}"
      GF_ALERTING_ENABLED: false
      GF_UNIFIED_ALERTING_ENABLED: false
      GF_PANELS_DISABLE_SANITIZE_HTML: false
    restart: unless-stopped
    cpus: 1
    depends_on:
      - prometheus

  # Exporters
  docker_stats_exporter:
    image: wywywywy/docker_stats_exporter:latest
    <<: *network_config
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped

  {% if observability_enable_hdd_monitoring %}

  smartctl_exporter:
    image: "ghcr.io/home-operations/smartctl-exporter:0.14"
    <<: *network_config
    container_name: smartctl_exporter
    privileged: true
    user: root
    volumes:
      - /dev:/dev:ro
      - /proc:/proc:ro
      - /sys:/sys:ro
      - /etc:/etc:ro
    environment:
      - SMARTCTL_ARGS=--json
    restart: unless-stopped
            healthcheck:
          test: [ "CMD", "wget", "--spider", "http://localhost:{{ observability_smartctl_exporter_port }}/" ]
          interval: 30s
          timeout: 10s
          retries: 3

  {% endif %}

  {% if observability_enable_alertmanager %}

  alertmanager:
    image: "prom/alertmanager:v0.30.0"
    <<: *network_config
    volumes:
      - /home/observability/alertmanager/data:/alertmanager
      - /home/observability/alertmanager/config:/etc/alertmanager
    command:
      - '--config.file=/etc/alertmanager/alertmanager.yml'
      - '--storage.path=/alertmanager'
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "wget", "--spider", "http://localhost:9093/-/healthy" ]
      interval: 30s
      timeout: 10s
      retries: 3

  {% endif %}

  {% if observability_enable_adguard_exporter %}

  adguard_exporter:
    image: "ghcr.io/henrywhitaker3/adguard-exporter:latest"
    <<: *network_config
    environment:
      ADGUARD_SERVERS: "{{ observability_adguard_url }}"
      ADGUARD_USERNAMES: "{{ observability_adguard_username }}"
      ADGUARD_PASSWORDS: "{{ observability_adguard_password }}"
    restart: unless-stopped

  {% endif %}

  {% if observability_qingping_enabled %}

  qingping_exporter:
    image: ghcr.io/pedro-stanaka/qingping_exporter/exporter:v0.2.2
    <<: *network_config
    container_name: qingping_exporter
    environment:
      QINGPING_APP_KEY: {{ observability_qingping_api_key }}
      QINGPING_APP_SECRET: {{ observability_qingping_api_secret }}
    restart: unless-stopped
    healthcheck:
      test: [ "CMD", "wget", "--spider", "http://localhost:10803/-/healthy" ]
      interval: 30s
      timeout: 10s
      retries: 3

  # Get weather data from OpenWeatherMap
  weather_exporter:
    image: billykwooten/openweather-exporter:latest
    <<: *network_config
    container_name: weather_exporter
    restart: always
    environment:
      - OW_CITY={{ o11y_weather_city }}
      - OW_APIKEY={{ o11y_openweathermap_api_key }}
      - OW_ENABLE_POL=true
      - OW_DEGREES_UNIT=C

  {% endif %}
